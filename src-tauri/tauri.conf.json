{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "assets_gen",
  "version": "0.4.1",
  "identifier": "com.assetsgen.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "assets_gen — atelier 3D & audio",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../worker_dist/worker": "worker",
      "../vendor/uv/uv.exe": "uv/uv.exe",
      "../hunyuan_overlay": "hunyuan_overlay"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
